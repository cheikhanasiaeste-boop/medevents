# Postgres connection (used by Alembic, Python ingest, and Next.js)
DATABASE_URL=postgresql://medevents:medevents@localhost:5432/medevents

# Admin auth (Argon2id hash; generate with `pnpm --filter @medevents/web exec node scripts/hash-password.mjs`)
ADMIN_PASSWORD_HASH=

# iron-session signing secret (32+ chars random hex; generate with `openssl rand -hex 32`)
IRON_SESSION_PASSWORD=

# CSRF signing secret (32+ chars random hex)
CSRF_SECRET=
